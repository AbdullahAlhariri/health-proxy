---
import { connectDb } from '../lib/db';

let dbError: string | null = null;
try {
  await connectDb();
} catch (e: any) {
  dbError = e?.message ?? 'database unreachable';
}
---

<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{dbError ? "Unhealthy receiver" : "Healthy receiver"}</title>
  </head>
  <body>
      {dbError ? "Unhealthy receiver" : "Healthy receiver"}
  </body>
</html>
