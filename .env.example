# Connection string used by the Astro app (docker-compose overrides this)
MONGODB_URI=mongodb://mongo:27017/healthdata

# Shared secret. Configure the SAME value as a custom header in the
# HC Webhook app:   X-Webhook-Secret: <this value>
WEBHOOK_SECRET=change-me-to-something-long-and-random

# Timezone used for "the night of <date>" queries and the dashboard
TIMEZONE=Europe/Amsterdam
